# ── BoxTrace backend configuration ───────────────────────────────
# Copy to .env and adjust for your environment.

# HTTP
PORT=4000
# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=12h
# First-run seed admin (created by `npm run db:seed`)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=ผู้ดูแลระบบ

# Database
# When USE_PGLITE=true an in-process WASM Postgres is used (no server needed) —
# handy for tests / quick local runs. Data is stored under PGLITE_DIR.
# For real deployments set USE_PGLITE=false and point DATABASE_URL at Postgres 16.
USE_PGLITE=false
PGLITE_DIR=./.pglite
DATABASE_URL=postgres://boxtrace:boxtrace@localhost:5432/boxtrace
